public class JourneyManager {
    private ArrayList<Journey> journeys;
    private Scanner scanner;

    private String journeysFile;
    private String profileFile;
    private String configFile;

    private String activeName;
    private String activePassengerType;
    private String activeDefaultPayment;
    private int nextId;

    private HashMap<String, BigDecimal> baseFares;
    private HashMap<String, BigDecimal> discountRates;
    private HashMap<String, BigDecimal> dailyCaps;
    private String peakStart;
    private String peakEnd;

    private final String adminPassword = "admin123";

     public JourneyManager() {
        scanner = new Scanner(System.in);
        journeysFile = "journeys.csv";
        profileFile = "profile.json";
        configFile = "config.json";
        journeys = new ArrayList<>();
        activeName = "";
        activePassengerType = "";
        activeDefaultPayment = "";
        nextId = 1;

        setDefaultConfig();
        loadConfig();
        loadProfile();
        loadJourneys();
        rebuildAllCharges();
    }

    public void start() {
        int choice;
        do {
            showMainMenu();
            choice = readInt("Enter your choice: ");

            switch (choice) {
                case 1:
                    riderMenu();
                    break;
                case 2:
                    adminMenu();
                    break;
                case 3:
                    exitProgram();
                    break;
                default:
                    System.out.println("Invalid choice. Try again.");
            }
        } while (choice != 3);

        scanner.close();
    }

